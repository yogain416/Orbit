{
  "name": "orbit",
  "version": "1.12.1",
  "description": "Orbit — 개인과 팀의 일정·할일·프로젝트를 잇는 운영 OS",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "predev": "electron-builder install-app-deps",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "pretest": "npm rebuild better-sqlite3",
    "test:watch": "vitest",
    "gen-icon": "node scripts/generate-icon.mjs",
    "package": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "prerelease": "electron-builder install-app-deps",
    "prepackage": "electron-builder install-app-deps",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.9",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.8",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.orbit.app",
    "productName": "Orbit",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yogain416",
        "repo": "Orbit"
      }
    ],
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Orbit"
    }
  }
}
